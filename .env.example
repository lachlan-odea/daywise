# Firebase web app configuration.
# Copy this file to `.env` and paste the values from your Firebase project:
#   Firebase console → Project settings → General → Your apps → SDK setup (Config).
# These values are safe to expose in a client app; access is controlled by
# Firebase Authentication and Firestore Security Rules, not by hiding them.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Google Apps Script web app URL for feedback → Google Sheet (see FEEDBACK_SETUP.md)
VITE_FEEDBACK_ENDPOINT=
